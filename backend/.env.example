# Copy to .env and fill in real values. NEVER commit the real .env (it is gitignored).
# Values below show the PRODUCTION shape for cokerflux.xyz. For local dev, set
# DEBUG=True and use the localhost values shown in comments.

# ── Core ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-freshly-generated-secret-key

# Production MUST be False. (local dev: True)
DEBUG=False

# Comma-separated, no scheme. (local dev: localhost,127.0.0.1)
ALLOWED_HOSTS=cokerflux.xyz,www.cokerflux.xyz,api.cokerflux.xyz

# ── Frontend URL (used in email links, and as the CORS/CSRF default) ──────────
# (local dev: http://localhost:5173)
FRONTEND_URL=https://cokerflux.xyz

# ── CORS / CSRF (comma-separated, WITH scheme) ────────────────────────────────
# Defaults to FRONTEND_URL if unset. Set explicitly if the site is reachable on
# more than one origin (e.g. apex + www).
CORS_ALLOWED_ORIGINS=https://cokerflux.xyz,https://www.cokerflux.xyz
CSRF_TRUSTED_ORIGINS=https://cokerflux.xyz,https://www.cokerflux.xyz

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=Cokerflux <wurldblog@gmail.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=wurldblog@gmail.com
# Google Account → Security → 2-Step Verification → App passwords. 16 chars, no spaces.
EMAIL_HOST_PASSWORD=replace-with-a-freshly-generated-gmail-app-password
CONTACT_RECIPIENT_EMAIL=cokerflux.ng@gmail.com
